    {
      "id": "wf2-n02",
      "name": "메시지 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [550, 300],
      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst text = (msg.message?.text || '').trim();\nconst chatId = msg.message?.chat?.id?.toString() || '';\nconst match = text.match(/^(PT-\\d{4}-\\d{3})\\s*(보고서|report)/i);\n\nreturn [{\n  json: {\n    raw_text: text,\n    chat_id: chatId,\n    patient_code: match ? match[1] : null,\n    is_valid_command: !!match,\n    parsed_at: $now.toISO(),\n    root_folder_id: $env.PATIENT_DRIVE_ROOT_FOLDER_ID\n  }\n}];"
      }
    },
