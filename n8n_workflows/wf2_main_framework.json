    {
      "id": "wf2-n18",
      "name": "면담 데이터 병합",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4450, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// extractFromFile이 binary 데이터를 내장 처리\n// 결과: item.json.interview_data = 파싱된 JSON 오브젝트\nconst allItems = $input.all();\n\n// interview_data 필드가 있는 아이템만 유효\nconst interviews = allItems\n  .filter(item => item.json.interview_data)\n  .map(item => item.json.interview_data);\n\nconst parseErrors = allItems.length - interviews.length;\n\n// 전체 텍스트 추출 (토큰 추정용)\nconst fullText = interviews.map(iv => {\n  // STT 트랜스크립트 형식 (WF1-B)\n  if (iv.transcript?.full_text) return iv.transcript.full_text;\n  // 체크리스트 형식 (WF1-A form_interview)\n  if (iv.checklist_data) {\n    const notes = Object.values(iv.checklist_data)\n      .flat()\n      .filter(q => q.note)\n      .map(q => `[${q.section}/${q.group}] ${q.question}: ${q.note}`)\n      .join('\\n');\n    return notes || `면담 기록 (날짜: ${iv.interview_date || 'unknown'})`;\n  }\n  if (iv.sections) return JSON.stringify(iv.sections);\n  return JSON.stringify(iv);\n}).join('\\n\\n---\\n\\n');\n\n// 한국어 토큰 추정: 글자수 / 1.5 ≈ 토큰 수\nconst estimatedTokens = Math.ceil(fullText.length / 1.5);\n\nconst patientCode = $('파일 목록 수집').first().json.patient_code;\nconst chatId = $('파일 목록 수집').first().json.chat_id;\n\nreturn [{\n  json: {\n    patient_code: patientCode,\n    chat_id: chatId,\n    merged_at: $now.toISO(),\n    interview_count: interviews.length,\n    parse_error_count: parseErrors,\n    estimated_tokens: estimatedTokens,\n    token_limit: 80000,\n    needs_pre_summary: estimatedTokens > 80000,\n    merged_interviews: interviews,\n    full_text_for_ai: fullText.substring(0, 500000)\n  }\n}];"
      }
    },
