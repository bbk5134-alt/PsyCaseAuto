    {
      "id": "wf2-n14",
      "name": "파일 목록 수집",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3250, 300],
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst files = allItems.map(item => ({\n  id: item.json.id,\n  name: item.json.name,\n  createdTime: item.json.createdTime\n}));\n\nconst patientCode = $('환자 폴더 ID 확정').first().json.patient_code;\nconst chatId = $('환자 폴더 ID 확정').first().json.chat_id;\n\nreturn [{\n  json: {\n    patient_code: patientCode,\n    chat_id: chatId,\n    patient_folder_id: $('환자 폴더 ID 확정').first().json.patient_folder_id,\n    interview_files: files,\n    file_count: files.length\n  }\n}];"
      }
    },
    {
      "id": "wf2-n14b",
      "name": "파일 목록 펼치기",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3400, 300],
      "parameters": {
        "jsCode": "const files = $input.first().json.interview_files;\nconst patientCode = $input.first().json.patient_code;\nconst chatId = $input.first().json.chat_id;\nconst patientFolderId = $input.first().json.patient_folder_id;\n\nreturn files.map(file => ({\n  json: {\n    id: file.id,\n    name: file.name,\n    createdTime: file.createdTime,\n    patient_code: patientCode,\n    chat_id: chatId,\n    patient_folder_id: patientFolderId\n  }\n}));"
      }
