        528,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nif (data.source === 'n8n_form') return [{ json: data }];\ntry {\n  const expected = $env.WEBHOOK_SECRET_WF1A || '';\n  const headers = $('Webhook').first().json.headers || {};\n  const received = headers['x-webhook-secret'] || '';\n  if (expected && received !== expected) throw new Error('UNAUTHORIZED: Webhook secret mismatch');\n} catch (e) { if (e.message.includes('UNAUTHORIZED')) throw e; }\nreturn [{ json: data }];"
      },
      "id": "wf1a-0004-4000-8000-000000000004",
      "name": "시크릿 검증",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const { raw } = $input.first().json;\nif (!/^PT-\\d{4}-\\d{3}$/.test(raw.patient_code)) throw new Error(`VALIDATION: 환자코드 형식 오류 \"${raw.patient_code}\"`);\nif (!raw.interview_date || !/^\\d{4}-\\d{2}-\\d{2}$/.test(raw.interview_date)) throw new Error(`VALIDATION: 날짜 형식 오류 \"${raw.interview_date}\"`);\nif (raw.source === 'html_checklist' && raw.checklist_data) {\n  let ok = false;\n  for (const items of Object.values(raw.checklist_data)) {\n    if (Array.isArray(items) && items.some(i => i.checked || (i.note && i.note.trim()))) { ok = true; break; }\n  }\n  if (!ok) throw new Error('VALIDATION: 체크리스트 입력 없음');\n}\nreturn [{ json: { raw, source: raw.source } }];"
      },
