      {
        "parameters": {
          "jsCode": "const data = $input.first().json;\nif (data.source === 'n8n_form') return [{ json: data }];\ntry {\n  const expected = $env.WEBHOOK_SECRET_WF1A || '';\n  const headers = $('Webhook').first().json.headers || {};\n  const received = headers['x-webhook-secret'] || '';\n  if (expected && received !== expected) throw new Error('UNAUTHORIZED: Webhook secret mismatch');\n} catch (e) { if (e.message.includes('UNAUTHORIZED')) throw e; }\nreturn [{ json: data }];"
        },
