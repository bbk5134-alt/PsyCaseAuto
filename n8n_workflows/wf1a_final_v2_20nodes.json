      {
        "parameters": {
          "jsCode": "const input = $input.first().json;\nlet raw, source;\nif (input.body) {\n  raw = typeof input.body === 'string' ? JSON.parse(input.body) : input.body;\n  source = 'html_checklist';\n} else {\n  raw = {\n    patient_code: (input.patient_code || '').toUpperCase().trim(),\n    interview_date: input.interview_date || '',\n    interviewer: input.interviewer || '',\n    interview_type: input.interview_type || 'initial',\n    submitted_at: $now.toISO(),\n    checklist_data: null,\n    free_text: {\n      chief_problems: input.chief_problems_notes || null,\n      present_illness: input.present_illness_notes || null,\n      past_history: input.past_history || null,\n      personal_history: input.personal_history || null,\n      mse_observations: input.mse_observations || null,\n      additional_notes: input.additional_notes || null\n    },\n    summary: null\n  };\n  source = 'n8n_form';\n}\nraw.patient_code = (raw.patient_code || '').toUpperCase().trim();\nraw.source = source;\nreturn [{ json: { raw, source } }];"
        },
        "id": "wf1a-0003-4000-8000-000000000003",
        "name": "입력 소스 통일",
