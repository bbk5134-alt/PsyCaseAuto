      {
        "parameters": {
          "jsCode": "const allFiles = $input.all();\nconst cnt = allFiles.filter(f => f.json.name && f.json.name.startsWith('interview_')).length;\nconst num = cnt + 1;\nconst { raw, source } = $('입력 검증').first().json;\nconst fId = $('interviews ID 확정').first().json.interviewsFolderId;\nconst sd = {\n  data_type:'form_interview', patient_code:raw.patient_code,\n  interview_number:num, interview_date:raw.interview_date,\n  interviewer:raw.interviewer||'', interview_type:raw.interview_type||'initial',\n  source, created_at:$now.toISO(),\n  checklist_data:raw.checklist_data||null, free_text:raw.free_text||null,\n  summary:raw.summary||null,\n  sections:(()=>{\n    if(source==='html_checklist'&&raw.checklist_data){\n      const n=[];\n      for(const[s,its]of Object.entries(raw.checklist_data)){\n        if(Array.isArray(its))its.forEach(i=>{if(i.note&&i.note.trim())n.push({section:s,group:i.group||'',question:i.question||'',checked:!!i.checked,note:i.note});});\n      }\n      return{_raw_notes:n};\n    }\n    if(raw.free_text)return{chief_problems_notes:raw.free_text.chief_problems,present_illness_notes:raw.free_text.present_illness,past_history:raw.free_text.past_history,personal_history:raw.free_text.personal_history,mse_observations:raw.free_text.mse_observations,additional_notes:raw.free_text.additional_notes};\n    return{};\n  })()\n};\nconst fn=`interview_${raw.interview_date.replace(/-/g,'')}.json`;\nconst buf=Buffer.from(JSON.stringify(sd,null,2),'utf-8');\nreturn[{json:{interviewsFolderId:fId,fileName:fn,patientCode:raw.patient_code,interviewNumber:num,source},binary:{data:{data:buf.toString('base64'),mimeType:'application/json',fileName:fn}}}];"
