# ── n8n 인증 ──────────────────────────────────────────────
N8N_BASIC_AUTH_USER=your_username
N8N_BASIC_AUTH_PASSWORD=your_password

# ── n8n 암호화 키 (무작위 32자 이상 문자열) ──────────────────
N8N_ENCRYPTION_KEY=your_random_encryption_key_here

# ── 타임존 및 데이터 설정 ─────────────────────────────────────
GENERIC_TIMEZONE=Asia/Seoul
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# ── AI API 키 ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── 텔레그램 (PsyCaseAuto 전용 봇 — 웨딩 프로젝트와 분리) ────────
# 같은 n8n 인스턴스를 공유하므로 변수명에 _PSYCH 접미사 사용
# n8n Code 노드에서: $env.TELEGRAM_BOT_TOKEN_PSYCH
TELEGRAM_BOT_TOKEN_PSYCH=your_psycaseauto_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id

# ── Google Drive (서비스 계정 JSON 문자열, 줄바꿈 없이) ──────────
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# ── Google Drive 폴더 ID ───────────────────────────────────
PATIENT_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# ── 에러 핸들링 워크플로우 (배포 후 채울 것) ─────────────────────
ERROR_WORKFLOW_ID=
